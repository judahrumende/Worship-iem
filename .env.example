# Server
PORT=3000

# Postgres (required for rooms API and auth)
DATABASE_URL=postgresql://user:pass@localhost:5432/worshipiem

# Redis (optional — falls back to in-memory if not set)
REDIS_URL=redis://localhost:6379

# JWT signing secret — CHANGE THIS in production
JWT_SECRET=change-me-to-something-long-and-random

# TURN server (optional — WebRTC still works on LAN without it)
# Free credentials: https://www.metered.ca/tools/openrelay/
TURN_URLS=turn:openrelay.metered.ca:80,turn:openrelay.metered.ca:443?transport=tcp
TURN_USERNAME=
TURN_CREDENTIAL=
